alert http any any -> any any (
    msg:"VDKJ SQL Injection Attempt";
    content:"union select";
    nocase;
    sid:1000001;
    rev:1;
)

alert http any any -> any any (
    msg:"VDKJ XSS Attempt";
    content:"<script>";
    nocase;
    sid:1000002;
    rev:1;
)

alert tcp any any -> any any (
    msg:"VDKJ Port Scan";
    flags:S;
    threshold:type both,track by_src,count 20,seconds 10;
    sid:1000003;
    rev:1;
)
