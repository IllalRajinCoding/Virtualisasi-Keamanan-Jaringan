<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> — Employee Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="app-layout">

  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">👥</div>
      <div>
        <span class="brand-name">Employee Portal</span>
        <span class="brand-tag">VDKJ · App 2</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/employees"     class="nav-link"><span class="nav-icon">👤</span> Daftar Karyawan</a>
      <a href="/employees/add" class="nav-link active"><span class="nav-icon">➕</span> Tambah Karyawan</a>
    </nav>
    <div class="sidebar-footer">
      <div class="server-badge">
        <span class="dot green"></span>
        <span>Server Online</span>
      </div>
      <small>7.7.7.2:3001 · app2_db</small>
    </div>
  </aside>

  <main class="main-content">
    <header class="page-header">
      <div>
        <h1 class="page-title"><%= pageTitle %></h1>
        <p class="page-subtitle"><%= employee ? 'UPDATE employees SET ... WHERE id=' + employee.id : 'INSERT INTO employees ...' %></p>
      </div>
      <a href="/employees" class="btn btn-secondary">← Kembali</a>
    </header>

    <% if (error) { %>
      <div class="alert alert-danger">⚠️ <%= error %></div>
    <% } %>

    <div class="form-card">
      <form method="POST" action="<%= formAction %>">
        <div class="form-group">
          <label for="fullname" class="form-label">Nama Lengkap</label>
          <input
            type="text"
            id="fullname"
            name="fullname"
            class="form-input"
            placeholder="Contoh: Budi Santoso"
            value="<%= employee ? employee.fullname : '' %>"
            required
            autocomplete="off"
          >
        </div>

        <div class="form-group">
          <label for="department" class="form-label">Departemen</label>
          <input
            type="text"
            id="department"
            name="department"
            class="form-input"
            placeholder="Contoh: IT, Finance, HR, Marketing"
            value="<%= employee ? employee.department : '' %>"
            required
            autocomplete="off"
          >
          <small class="form-hint">Isi dengan nama departemen tempat karyawan bertugas.</small>
        </div>

        <div class="form-actions">
          <a href="/employees" class="btn btn-secondary">Batal</a>
          <button type="submit" class="btn btn-primary">
            <%= employee ? '💾 Simpan Perubahan' : '➕ Tambah Karyawan' %>
          </button>
        </div>
      </form>
    </div>
  </main>
</div>
</body>
</html>
